#Copeland's Corporate Company user name and temp password definition and creation.

#We are creating 2 functions: username_generator and password_generator. 
#The first one creates an user name from the 3 first letters of the first name and the four first letters of the last name, returning a seven letter user name.
# THe second function takes this user name and generates a temp password moving one character to the right from the user name to the password.


def username_generator(first_name, last_name):
  #Considering the case when the first_name has less than 3 characters, we introduce a condition. Generating the first part of the new user_name.
  first_part_pass = None
  if len(first_name) <= 3:
    first_part_pass = first_name
  else: first_part_pass = first_name[:3]
  
  #Considering the case when the last_name has less than 4 characters, we introduce a condition. Generating the second part of the new user_name.
  second_part_pass = None

  if len(last_name) <= 4:
    second_part_pass = last_name
  else: second_part_pass = last_name[:4]
  
  #Now we concatenate the two parts to generate the fill user_name.
  user_name = first_part_pass + second_part_pass
  return user_name

#Testing
user_name = username_generator("Abe", "Simpson") 
